#!/bin/bash

TARGET_USER=$(id -nu 1000)
MPC_CMD="sudo -u $TARGET_USER MPD_HOST=127.0.0.1 MPD_PORT=6600 /usr/bin/mpc"
MOUNT_POINT="/mnt/music"

# Слушаем СИСТЕМНУЮ шину (--system) конкретно на предмет изменений в устройствах Bluetooth
dbus-monitor --system "type='signal',sender='org.bluez',interface='org.freedesktop.DBus.Properties',member='PropertiesChanged'" | while read -r line; do
    
    # Если в потоке D-Bus промелькнуло событие подключения
    if echo "$line" | grep -q "Connected"; then
        
        # Даем 1.5 секунды, чтобы WirePlumber гарантированно увидел устройство
        sleep 1.5
        
        # Проверяем, подключено ли устройство на самом деле (защита от ложных сигналов отключения)
        if bluetoothctl info | grep -q "Connected: yes"; then
            
            # Шаг 1: Проверяем, примонтирована ли флешка (проверяем точку монтирования через mountpoint)
            if mountpoint -q "$MOUNT_POINT"; then
                echo "Наушники подключены, флешка на месте. Запускаем плеер."
                
                # Шаг 2: Проверяем статус MPD. Если он не играет — включаем музыку
                CURRENT_STATUS=$($MPC_CMD status | grep -E "\[playing\]")
                if [ -z "$CURRENT_STATUS" ]; then
                    $MPC_CMD play
                fi
            else
                echo "Наушники подключены, но флешка не вставлена. Музыка не будет запущена."
            fi
        fi
    fi
done
