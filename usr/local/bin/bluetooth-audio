#!/bin/bash

# Подключаем общую библиотеку функций проекта
source /usr/local/bin/player-functions

# Ссылка на точку монтирования берется из библиотеки, но для надежности продублируем
MOUNT_POINT="/mnt/music"

# Непрерывно слушаем системный D-Bus от BlueZ
dbus-monitor --system "type='signal',sender='org.bluez',interface='org.freedesktop.DBus.Properties',member='PropertiesChanged'" | while read -r line; do
    
    # Если зафиксирован сигнал подключения устройства
    if echo "$line" | grep -q "Connected"; then
        
        # Выдерживаем паузу в 1.5 секунды для инициализации аудиовыхода в WirePlumber
        sleep 1.5
        
        # Проверяем, на связи ли наушники на самом деле (защита от ложного срабатывания на отключение)
        if is_bluetooth_ready; then
            
            # Проверяем, вставлена ли флешка в берестяной тубус
            if mountpoint -q "$MOUNT_POINT"; then
                
                # Считываем положение гравитационного датчика (3-я линия на gpiochip1)
                # Если плеер перевернут и "спит", то включать музыку от случайного коннекта наушников нельзя
                GRAVITY_STATE=$(gpioget -c "gpiochip1" 3 | cut -d'=' -f2 | tr -d '"')
                
                if [ "$GRAVITY_STATE" = "active" ]; then
                    echo "Наушники подключились, но плеер перевернут (спит). Воспроизведение заблокировано." | logger -t bluetooth-audio
                else
                    echo "Наушники подключены, флешка на месте, плеер стоит ровно. Запускаем плеер." | logger -t bluetooth-audio
                    
                    # Проверяем статус MPD. Если он не играет — включаем музыку умным способом
                    CURRENT_STATUS=$(run_mpc status "%queuepos%" 2>/dev/null)
                    if [ -z "$CURRENT_STATUS" ] || [ "$CURRENT_STATUS" = "0" ] || run_mpc status | grep -q "paused"; then
                        
                        # [НАДЕЖНО] Жестко гасим Wi-Fi интерфейс, чтобы убрать заикания звука
                        ip link set wlan0 down 2>/dev/null || true
                        
                        # Вызываем интеллектуальный запуск из библиотеки (с подхватом секунд)
                        start_playback
                    fi
                fi
            else
                echo "Наушники подключены, но флешка отсутствует. Музыка не будет запущена." | logger -t bluetooth-audio
            fi
        fi
    fi
done
