#!/bin/bash

# Переменная для отслеживания текущего состояния (0 - норма, 1 - перевернут)
# При старте проверяем реальное положение (используем gpioget)
LAST_STATE=$(gpioget $(gpiofind "GPIOAO_3"))

# Запускаем мониторинг прерываний на линии GPIOAO_3
gpiomon --falling --rising $(gpiofind "GPIOAO_3") | while read -r line; do
    # gpiomon выплевывает строку при каждом изменении. Читаем текущий статус заново:
    CURRENT_STATE=$(gpioget $(gpiofind "GPIOAO_3"))
    
    if [ "$CURRENT_STATE" != "$LAST_STATE" ]; then
        if [ "$CURRENT_STATE" -eq 1 ]; then
            # Цепь разомкнулась (шарик улетел) -> плеер перевернули
            /usr/local/bin/gravity-player sleep
        else
            # Цепь замкнулась на GND -> плеер вернули на ноги
            /usr/local/bin/gravity-player wake
        fi
        LAST_STATE=$CURRENT_STATE
    fi
done
