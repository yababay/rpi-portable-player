#!/bin/bash

CHIP="gpiochip1"
LINE=3

# Функция для получения чистого статуса (active или inactive) без кавычек
get_clean_state() {
    gpioget -c "$CHIP" "$LINE" | cut -d'=' -f2 | tr -d '"'
}

echo "Запуск gravity-daemon. Мониторинг линии $LINE на $CHIP..." | logger -t gravity-daemon

LAST_STATE=$(get_clean_state)
echo "Начальное состояние датчика: $LAST_STATE" | logger -t gravity-daemon

# В gpiod v2.x gpiomon выводит события при каждом изменении уровня.
# Мы просто реагируем на факт вывода новой строки утилитой gpiomon
gpiomon -c "$CHIP" "$LINE" | while read -r event; do
    CURRENT_STATE=$(get_clean_state)
    
    # Логируем сырое событие для отладки
    echo "Перехват прерывания. Текущее состояние: $CURRENT_STATE, Прошлое: $LAST_STATE" | logger -t gravity-daemon
    
    if [ "$CURRENT_STATE" != "$LAST_STATE" ]; then
        if [ "$CURRENT_STATE" = "active" ]; then
            echo "Датчик сработал: active (корпус перевернут). Вызов gravity-player sleep..." | logger -t gravity-daemon
            /usr/local/bin/gravity-player sleep 2>&1 | logger -t gravity-daemon
        elif [ "$CURRENT_STATE" = "inactive" ]; then
            echo "Датчик сработал: inactive (корпус возвращен). Вызов gravity-player wake..." | logger -t gravity-daemon
            /usr/local/bin/gravity-player wake 2>&1 | logger -t gravity-daemon
        fi
        LAST_STATE=$CURRENT_STATE
    fi
done
