#!/bin/bash

CHIP="gpiochip1"
LINE=3

# Считываем стартовое состояние (возвращает "3"=active или "3"=inactive)
# Вырезаем только само слово после знака равенства
LAST_STATE=$(gpioget -c "$CHIP" "$LINE" | cut -d'=' -f2)

# Запускаем мониторинг линии
gpiomon -c "$CHIP" "$LINE" | while read -r event; do
    # Как только прилетело событие прерывания, считываем актуальный статус пина
    CURRENT_STATE=$(gpioget -c "$CHIP" "$LINE" | cut -d'=' -f2)
    
    # Защита от дребезга контактов шарика: если состояние действительно изменилось
    if [ "$CURRENT_STATE" != "$LAST_STATE" ]; then
        if [ "$CURRENT_STATE" = "active" ]; then
            # Цепь разомкнулась, сработала подтяжка -> плеер перевернули вверх дном
            /usr/local/bin/gravity-player sleep
        elif [ "$CURRENT_STATE" = "inactive" ]; then
            # Цепь замкнулась на GND -> плеер вернули в нормальное положение
            /usr/local/bin/gravity-player wake
        fi
        LAST_STATE=$CURRENT_STATE
    fi
done
