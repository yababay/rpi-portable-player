#!/bin/bash

TARGET_USER=$(id -nu 1000)
MPC_CMD="sudo -u $TARGET_USER MPD_HOST=127.0.0.1 MPD_PORT=6600 /usr/bin/mpc"

case "$1" in
    sleep)
        echo "Плеер перевернут. Засыпаем..."
        # Ставим музыку на паузу
        $MPC_CMD pause
        # Принудительно отключаем наушники, чтобы они заснули
        bluetoothctl disconnect
        # Переводим процессор в ультра-экономичный режим
        echo "powersave" | tee /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor > /dev/null
        ;;
    wake)
        echo "Плеер возвращен в рабочее положение. Просыпаемся..."
        
        # 1. Возвращаем процессору режим автоматической частоты
        echo "ondemand" | tee /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor > /dev/null
        
        # 2. Динамически находим MAC-адрес наушников
        BT_MAC=$(bluetoothctl devices | grep -E "JBL|audio-headset|headphone" | head -n 1 | awk '{print $2}')
        if [ -z "$BT_MAC" ]; then
            BT_MAC=$(bluetoothctl paired-devices | head -n 1 | awk '{print $2}')
        fi

        if [ -n "$BT_MAC" ]; then
            echo "Инициируем обратное подключение к наушникам: $BT_MAC..."
            
            # Уводим подключение и инициализацию в фоновый поток
            (
                bluetoothctl connect "$BT_MAC" >/dev/null 2>&1
                
                # Ждем 2.5 секунды, чтобы WirePlumber поднял профиль A2DP
                sleep 2.5
                
                # Проверяем, на связи ли наушники
                if bluetoothctl info "$BT_MAC" | grep -q "Connected: yes"; then
                    echo "Наушники успешно подключены. Вызываем главный диспетчер music-mount..." | logger -t gravity-player
                    
                    # Передаем управление music-mount. Он проверит флешку, 
                    # гарантированно погасит Wi-Fi и включит музыку с нужной секунды.
                    /usr/local/bin/music-mount start
                else
                    echo "Не удалось восстановить связь с наушниками автоматически." | logger -t gravity-player
                fi
            ) &
        else
            echo "Предупреждение: Не удалось найти сопряженные Bluetooth-устройства."
        fi
        ;;
esac
