#!/bin/bash

# Подключаем общую библиотеку функций
source /usr/local/bin/player-functions

case "$1" in
    sleep)
        echo "Плеер перевернут. Засыпаем..."
        run_mpc pause >/dev/null 2>&1 || true
        bluetoothctl disconnect
        echo "powersave" | tee /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor > /dev/null
        ip link set wlan0 up 2>/dev/null || true
        ;;
        
    wake)
        echo "Плеер возвращен в рабочее положение. Просыпаемся..."
        echo "ondemand" | tee /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor > /dev/null
        
        # Ищем MAC-адрес наушников
        BT_MAC=$(bluetoothctl devices | grep -E "JBL|audio-headset|headphone" | head -n 1 | awk '{print $2}')
        if [ -z "$BT_MAC" ]; then
            BT_MAC=$(bluetoothctl paired-devices | head -n 1 | awk '{print $2}')
        fi

        if [ -n "$BT_MAC" ]; then
            echo "Инициируем обратное подключение к наушникам: $BT_MAC..."
            (
                bluetoothctl connect "$BT_MAC" >/dev/null 2>&1
                sleep 2.5
                
                if bluetoothctl info "$BT_MAC" | grep -q "Connected: yes"; then
                    echo "Наушники подключены. Глушим Wi-Fi и включаем звук." | logger -t gravity-player
                    ip link set wlan0 down 2>/dev/null || true
                    
                    # Вызываем интеллектуальный запуск из библиотеки
                    start_playback
                else
                    echo "Ошибка: Не удалось восстановить связь." | logger -t gravity-player
                fi
            ) &
        else
            echo "Предупреждение: Не удалось найти сопряженные Bluetooth-устройства."
        fi
        ;;
esac
