#!/bin/bash

TARGET_USER=$(id -nu 1000)
MPC_CMD="sudo -u $TARGET_USER MPD_HOST=127.0.0.1 MPD_PORT=6600 /usr/bin/mpc"

case "$1" in
    sleep)
        echo "Плеер перевернут. Засыпаем..."
        # Ставим музыку на паузу
        $MPC_CMD pause
        # Принудительно отключаем наушники, чтобы они заснули
        bluetoothctl disconnect
        # Переводим процессор в ультра-экономичный режим
        echo "powersave" | tee /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor > /dev/null
        ;;
    wake)
        echo "Плеер возвращен в рабочее положение. Просыпаемся..." | logger -t gravity-player
        
        # 1. Возвращаем процессору нормальный режим
        echo "ondemand" | tee /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor > /dev/null
        
        # Функция для mpc
        run_mpc() {
            local target_user=$(id -nu 1000)
            sudo -u "$target_user" MPD_HOST=127.0.0.1 MPD_PORT=6600 /usr/bin/mpc "$@"
        }

        # 2. Ищем наушники
        BT_MAC=$(bluetoothctl devices | grep -E "JBL|audio-headset|headphone" | head -n 1 | awk '{print $2}')
        if [ -z "$BT_MAC" ]; then
            BT_MAC=$(bluetoothctl paired-devices | head -n 1 | awk '{print $2}')
        fi

        if [ -n "$BT_MAC" ]; then
            echo "Инициируем обратное подключение к наушникам: $BT_MAC..." | logger -t gravity-player
            
            (
                # Подключаем наушники
                bluetoothctl connect "$BT_MAC" >/dev/null 2>&1
                
                # Ждем инициализации аудио-профиля A2DP
                sleep 2.5
                
                if bluetoothctl info "$BT_MAC" | grep -q "Connected: yes"; then
                    echo "Наушники подключены. Глушим Wi-Fi и включаем воспроизведение." | logger -t gravity-player
                    
                    # [НАДЕЖНО] Жестко отключаем Wi-Fi прямо отсюда
                    ip link set wlan0 down 2>/dev/null || true
                    
                    # Запускаем музыку
                    run_mpc play
                else
                    echo "Ошибка: Не удалось восстановить связь с наушниками." | logger -t gravity-player
                fi
            ) &
        else
            echo "Предупреждение: Не удалось найти сопряженные Bluetooth-устройства." | logger -t gravity-player
        fi
        ;;
esac
