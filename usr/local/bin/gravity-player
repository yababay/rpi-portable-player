#!/bin/bash

TARGET_USER=$(id -nu 1000)
MPC_CMD="sudo -u $TARGET_USER MPD_HOST=127.0.0.1 MPD_PORT=6600 /usr/bin/mpc"

case "$1" in
    sleep)
        echo "Плеер перевернут. Засыпаем..."
        # Ставим музыку на паузу
        $MPC_CMD pause
        # Принудительно отключаем наушники, чтобы они заснули
        bluetoothctl disconnect
        # Переводим процессор в ультра-экономичный режим
        echo "powersave" | tee /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor > /dev/null
        ;;
    wake)
        echo "Плеер возвращен в рабочее положение. Просыпаемся..."
        
        # 1. Возвращаем процессору режим автоматической частоты
        echo "ondemand" | tee /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor > /dev/null
        
        # 2. Динамически находим MAC-адрес сопряженных и доверенных (trusted) наушников.
        # В вашем случае это будет 5C:FB:7C:E0:FC:56 (JBL T450BT).
        # Берем первое доступное аудио-устройство из списка спаренных.
        BT_MAC=$(bluetoothctl devices | grep -E "JBL|audio-headset|headphone" | head -n 1 | awk '{print $2}')
        
        # Если регулярное выражение выше ничего не нашло, берем просто любое спаренное устройство
        if [ -z "$BT_MAC" ]; then
            BT_MAC=$(bluetoothctl paired-devices | head -n 1 | awk '{print $2}')
        fi

        if [ -n "$BT_MAC" ]; then
            echo "Инициируем обратное подключение к наушникам: $BT_MAC..."
            # Запускаем подключение в фоне, чтобы скрипт не завис, если наушники выключены
            bluetoothctl connect "$BT_MAC" &
        else
            echo "Предупреждение: Не удалось найти сопряженные Bluetooth-устройства для подключения."
        fi
        ;;
esac
