#!/bin/bash

# Подключаем общую библиотеку функций
source /usr/local/bin/player-functions

DEVICE="/dev/music"
UUID=$(/sbin/blkid -o value -s UUID "$DEVICE")

if [ -z "$UUID" ]; then
    echo "Ошибка: Не удалось определить UUID для $DEVICE" >> /var/log/music-player.log
    exit 1
fi

case "$1" in
    start)
        # [НАДЕЖНО] Проверяем по системному логу ядра, примонтировано ли наше устройство /dev/music
        if ! grep -q " $MOUNT_POINT " /proc/mounts; then
            echo "Монтирование флешки $UUID в $MOUNT_POINT..."
            
            # Если в fstab уже есть запись, mount $MOUNT_POINT отработает идеально.
            # Если записи нет, сработает mount $DEVICE $MOUNT_POINT.
            mount "$MOUNT_POINT" 2>/dev/null || mount "$DEVICE" "$MOUNT_POINT" || exit 1
            
            # Обновляем базу данных MPD только при первом физическом монтировании
            run_mpc update || true

            # Заполнение очереди
            run_mpc clear
            if [ -f "$MOUNT_POINT/autoplay.m3u" ]; then
                run_mpc random off
                while read -r line || [ -n "$line" ]; do
                    [[ "$line" =~ ^# ]] && continue
                    [[ -z "$line" ]] && continue
                    run_mpc add "$line"
                done < "$MOUNT_POINT/autoplay.m3u"
            else
                # [НАДЕЖНО] Вместо listall просто добавляем корень точки монтирования.
                # MPD мгновенно забьет очередь путями, и музыка начнет играть сразу!
                run_mpc add "/"
                run_mpc random on
            fi        
        else
            echo "Устройство уже физически примонтировано в $MOUNT_POINT, пропускаем шаг mount."
        fi
        
        # Отключение Wi-Fi интерфейса для чистоты звука
        echo "Отключение Wi-Fi интерфейса..."
        ip link set wlan0 down 2>/dev/null || true

        # Проверяем датчик наклона
        GRAVITY_STATE=$(gpioget -c "gpiochip1" 3 | cut -d'=' -f2 | tr -d '"')
        if [ "$GRAVITY_STATE" = "active" ]; then
            echo "Плеер перевернут (режим сна). Ожидаем пробуждения."
        else
            if is_bluetooth_ready; then
                echo "Наушники на связи. Запуск музыки..."
                start_playback
            else
                echo "Наушники не найдены. Ожидание подключения..."
            fi
        fi
        ;;

    stop)
        echo "Сохранение состояния и размонтирование флешки $UUID..."
        
        # Пробуем сохранить позицию. Если MPD заклинило — пишем лог и идем дальше
        CURRENT_STATUS=$(run_mpc status "%queuepos%" 2>/dev/null)
        ELAPSED=$(run_mpc status "%elapsed%" 2>/dev/null)
        
        if [ -n "$CURRENT_STATUS" ] && [ "$CURRENT_STATUS" != "0" ]; then
            local state_file="$STATE_DIR/$UUID"
            echo "$CURRENT_STATUS $ELAPSED" > "$state_file"
        fi

        run_mpc stop >/dev/null 2>&1 || true
        run_mpc clear >/dev/null 2>&1 || true
        
        # Размонтируем физический носитель
        umount -l "$MOUNT_POINT"

        # Жесткий сброс MPD, чтобы стереть из его памяти "призрачные треки"
        restart_user_mpd
        run_mpc update || true >/dev/null 2>&1 || true

        # Возвращаем Wi-Fi для удаленного доступа
        echo "Включение Wi-Fi интерфейса..."
        ip link set wlan0 up 2>/dev/null || true
        ;;
esac
