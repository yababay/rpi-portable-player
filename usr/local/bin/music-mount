#!/bin/bash

# Настройки
MOUNT_POINT="/mnt/music"
STATE_DIR="/var/lib/mpd/usb_states"
mkdir -p "$STATE_DIR"

# Переменные от udev (работают, если сервис вызван правильно) или фолбек на blkid
# Для надежности берем UUID конкретно того устройства, которое активировало сервис
DEVICE="/dev/music"
UUID=$(/sbin/blkid -o value -s UUID "$DEVICE")

if [ -z "$UUID" ]; then
    echo "Ошибка: Не удалось определить UUID для $DEVICE" >> /var/log/music-player.log
    exit 1
fi

STATE_FILE="$STATE_DIR/$UUID"

# Функция для работы mpc от имени пользователя mabel (чтобы не было проблем с правами)
run_mpc() {
    sudo -u mabel MPD_HOST=127.0.0.1 MPD_PORT=6600 /usr/bin/mpc "$@"
}

# Функция для проверки, подключено ли хоть одно Bluetooth-аудиоустройство
is_bluetooth_ready() {
    # 1. Получаем список всех известных устройств
    # 2. Оставляем только те, у которых тип "audio-headset" (или наушники/колонки)
    # 3. Проверяем каждое активное устройство на флаг "Connected: yes"
    
    local connected_audio_found=0

    while read -r mac _; do
        if [ -n "$mac" ]; then
            if bluetoothctl info "$mac" | grep -q "Connected: yes"; then
                connected_audio_found=1
                break
            fi
        fi
    done < <(bluetoothctl devices | grep -E "audio-headset|headphone" | awk '{print $2}')

    # Если цикл выше ничего не нашел (в Armbian icon может не распарситься),
    # делаем фолбек — ищем вообще любое подключенное BT-устройство
    if [ "$connected_audio_found" -eq 0 ]; then
        if bluetoothctl info | grep -q "Connected: yes"; then
            connected_audio_found=1
        fi
    fi

    if [ "$connected_audio_found" -eq 1 ]; then
        return 0 # Устройство подключено
    else
        return 1 # Никого нет
    fi
}

# Функция для запуска воспроизведения с учетом сохраненного состояния
start_playback() {
    if [ -f "$STATE_FILE" ]; then
        read -r TRACK TIME < "$STATE_FILE"
        if [[ "$TRACK" =~ ^[0-9]+$ ]] && [[ "$TIME" =~ ^[0-9]+$ ]]; then
            run_mpc play "$TRACK"
            run_mpc seek "$TIME"
        else
            run_mpc play 1
        fi
    else
        # Если плейлист autoplay, то play 1, иначе (для listall) просто play
        if [ -f "$MOUNT_POINT/autoplay.m3u" ]; then
            run_mpc play 1
        else
            run_mpc play
        fi
    fi
}

case "$1" in
    start)
        echo "Монтирование флешки $UUID..."
        mount "$DEVICE" "$MOUNT_POINT" || exit 1
        
        run_mpc update
        run_mpc clear

        # Заполнение очереди (autoplay.m3u или listall)
        if [ -f "$MOUNT_POINT/autoplay.m3u" ]; then
            run_mpc random off
            while read -r line || [ -n "$line" ]; do
                [[ "$line" =~ ^# ]] && continue
                [[ -z "$line" ]] && continue
                run_mpc add "$line"
            done < "$MOUNT_POINT/autoplay.m3u"
        else
            run_mpc listall | run_mpc add
            run_mpc random on
        fi

        # ИНТЕЛЛЕКТУАЛЬНЫЙ СТАРТ:
        # Проверяем, подключено ли аудиоустройство прямо сейчас
        if is_bluetooth_ready; then
            echo "Bluetooth-аудио обнаружено. Включаю воспроизведение."
            start_playback
        else
            echo "Флешка готова, но Bluetooth-устройства не найдены. Ожидаем подключения наушников..."
            # Музыку не включаем. Очередь загружена, позиция будет прочитана, 
            # когда сработает Bluetooth-триггер.
        fi
        ;;
            stop)
        echo "Сохранение состояния и размонтирование флешки $UUID..."
        
        # Получаем текущий трек и позицию перед остановкой
        # mpc status выдает специфический формат, выдергиваем номер трека и секунды
        CURRENT_STATUS=$(run_mpc status "%queuepos% %time%")
        TRACK=$(echo "$CURRENT_STATUS" | awk '{print $1}')
        # Переводим mm:ss в секунды, если нужно, или используем сырые секунды %elapsed%
        ELAPSED=$(run_mpc status "%elapsed%")
        
        # Если плеер что-то играл, сохраняем это
        if [ -n "$TRACK" ] && [ "$TRACK" != "0" ]; then
            echo "$TRACK $ELAPSED" > "$STATE_FILE"
        fi

        # Останавливаем воспроизведение и очищаем очередь, чтобы MPD не держал файлы
        run_mpc stop
        run_mpc clear
        
        # Ленивое размонтирование (флешку уже могли выдернуть)
        umount -l "$MOUNT_POINT"
        ;;
esac
