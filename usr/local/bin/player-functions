#!/bin/bash

# Глобальные настройки путей
MOUNT_POINT="/mnt/music"
STATE_DIR="/var/lib/mpd/usb_states"
TARGET_USER=$(id -nu 1000 2>/dev/null || echo "mabel")

# Функция для работы mpc от имени пользователя с UID 1000
run_mpc() {
    sudo -u "$TARGET_USER" MPD_HOST=127.0.0.1 MPD_PORT=6600 /usr/bin/mpc "$@"
}

# Функция для жесткой реанимации MPD, если его декодер заклинило
restart_user_mpd() {
    echo "Реанимация пользовательского MPD..."
    sudo -u "$TARGET_USER" DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/1000/bus systemctl --user restart mpd.service
    sleep 0.5
}

# Функция для проверки, подключено ли хоть одно Bluetooth-аудиоустройство
is_bluetooth_ready() {
    local connected_audio_found=0

    while read -r mac _; do
        if [ -n "$mac" ]; then
            if bluetoothctl info "$mac" | grep -q "Connected: yes"; then
                connected_audio_found=1
                break
            fi
        fi
    done < <(bluetoothctl devices | grep -E "JBL|audio-headset|headphone" | awk '{print $2}')

    if [ "$connected_audio_found" -eq 0 ]; then
        if bluetoothctl info | grep -q "Connected: yes"; then
            connected_audio_found=1
        fi
    fi

    if [ "$connected_audio_found" -eq 1 ]; then
        return 0
    else
        return 1
    fi
}

# Централизованная функция запуска воспроизведения с учетом сохраненного состояния
start_playback() {
    # Считываем UUID текущей флешки, если она смонтирована
    local device="/dev/music"
    local uuid=$(/sbin/blkid -o value -s UUID "$device" 2>/dev/null)
    local state_file="$STATE_DIR/$uuid"

    if [ -n "$uuid" ] && [ -f "$state_file" ]; then
        read -r TRACK TIME < "$state_file"
        if [[ "$TRACK" =~ ^[0-9]+$ ]] && [[ "$TIME" =~ ^[0-9]+$ ]]; then
            echo "Восстановление сохраненной позиции: Трек $TRACK, Время $TIME"
            run_mpc play "$TRACK"
            run_mpc seek "$TIME"
        else
            run_mpc play 1
        fi
    else
        if [ -f "$MOUNT_POINT/autoplay.m3u" ]; then
            run_mpc play 1
        else
            run_mpc play
        fi
    fi
}
