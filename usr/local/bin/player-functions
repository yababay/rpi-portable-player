#!/bin/bash

# Глобальные настройки путей
MOUNT_POINT="/mnt/music"
TARGET_USER=$(id -nu 1000 2>/dev/null || echo "mabel")
USER_HOME=$(getent passwd "$TARGET_USER" | cut -d: -f6)
MPD_CONFIG_DIR="$USER_HOME/.config/mpd"
MPD_CONFIG_FILE="$MPD_CONFIG_DIR/mpd.conf"
BT_MAC_FILE="$MPD_CONFIG_DIR/bt_mac"

run_mpc() {
    sudo -u "$TARGET_USER" MPD_HOST=127.0.0.1 MPD_PORT=6600 /usr/bin/mpc "$@"
}

restart_user_mpd() {
    echo "Перезапуск пользовательского MPD..."
    sudo -u "$TARGET_USER" DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/1000/bus systemctl --user restart mpd.service
    sleep 0.8
}

get_uuid () {
    local device=$(mount | grep "/mnt/music" | egrep -o "^\/dev\/[a-z0-9]+")
    /sbin/blkid -o value -s UUID "$device" 2>/dev/null
}

get_state_file () {
    local uuid=$(get_uuid)
    echo "$MPD_CONFIG_DIR/$uuid/state"
}

get_gravity_state () {
    gpioget -c "gpiochip1" 3 | cut -d'=' -f2 | tr -d '"'
}

# Функция для динамического перестроения mpd.conf под конкретную флешку
update_mpd_config() {
    local uuid=$(get_uuid)
    local db_file_path="$MPD_CONFIG_DIR/tag_cache" # дефолт

    # Если UUID передан, используем выделенную базу данных
    if [ -n "$uuid" ]; then
        db_dir="$MPD_CONFIG_DIR/$uuid"
        db_file_path="$db_dir/tag_cache"
        # Создаем пустой файл базы, если флешка новая, чтобы у MPD были права
        mkdir -p "$db_dir"
        touch "$db_file_path"
        chown "$TARGET_USER:$TARGET_USER" "$db_dir" -R
    fi

    cat << EOF > "$MPD_CONFIG_FILE"
music_directory         "$MOUNT_POINT"
playlist_directory      "$MOUNT_POINT"
db_file                 "$db_file_path"
log_file                "$MPD_CONFIG_DIR/mpd.log"
pid_file                "$MPD_CONFIG_DIR/pid"
state_file              "$MPD_CONFIG_DIR/state"
sticker_file            "$MPD_CONFIG_DIR/sticker.sql"

audio_output {
        type            "pipewire"
        name            "PipeWire Bluetooth Output"
        mixer_type      "software"
}
EOF
    chown "$TARGET_USER:$TARGET_USER" "$MPD_CONFIG_FILE"
}

find_connected_audio () {
    rm -f "$BT_MAC_FILE"
    bluetoothctl devices | egrep -o '([0-9A-Fa-f]{2}:){5}[0-9A-Fa-f]{2}' | while read mac; do
        if bluetoothctl info "$mac" | grep -q "Connected: yes"; then
            echo "$mac" > "$BT_MAC_FILE"
            break
        fi
    done
}

is_bluetooth_ready() {
    local connected_audio_found=0
    while read -r mac _; do
        if [ -n "$mac" ]; then
            if bluetoothctl info "$mac" | grep -q "Connected: yes"; then
                connected_audio_found=1
                break
            fi
        fi
    done < <(bluetoothctl devices | grep -E "JBL|audio-headset|headphone" | awk '{print $2}')

    if [ "$connected_audio_found" -eq 0 ] && bluetoothctl info | grep -q "Connected: yes"; then
        connected_audio_found=1
    fi
    [ "$connected_audio_found" -eq 1 ] && return 0 || return 1
}

start_playback() {

    # Если директория с музыкой пуста:
    if [ -z "$(ls $MOUNT_POINT)" ]; then
        echo "Не удалось примонтировать флешку или флешка не вставлена."
        return 0
    fi

    # Проверяем гравитационный датчик.
    if [ "$(get_gravity_state)" == "active" ]; then
        echo "Проигрыватель перевёрнут, ждём пробуждения…"
        return 0
    fi

    # Проверяем аудиоустройство.
    find_connected_audio
    if [ ! -f "$BT_MAC_FILE" ]; then
        echo "Не удалось найти ни одного подключенного аудиоустройства."
        return 0
    fi

    # Включаем бесконечное воспроизведение.
    run_mpc repeat on

    # Если флешка не поменялась, просто включаем воспроизведение.
    local uuid=$(get_uuid)
    if [ -n "$(cat $MPD_CONFIG_FILE | grep $(get_uuid))" ]; then
        run_mpc play
        return 0
    fi

    # Пытаемся включить воспроизведение с другой флешки.
    update_mpd_config
    restart_user_mpd

    local state_file=$(get_state_file)

    if [ -f "$state_file" ]; then
        read -r TRACK TIME < "$state_file"
        if [[ "$TRACK" =~ ^[0-9]+$ ]] && [[ "$TIME" =~ ^[0-9]+$ ]]; then
            echo "Восстановление позиции: Трек $TRACK, Время $TIME"
            run_mpc play "$TRACK"
            run_mpc seek "$TIME"
        else
            run_mpc play 1
        fi
    else
        if [ -f "$MOUNT_POINT/autoplay.m3u" ]; then
            run_mpc load autoplay
        else 
            run_mpc listall | run_mpc add
            run_mpc shuffle
        fi
        run_mpc play 1
    fi
}

stop_playback () {

        # Пробуем сохранить позицию. Если MPD заклинило — пишем лог и идем дальше
        CURRENT_STATUS=$(run_mpc status "%queuepos%" 2>/dev/null)
        ELAPSED=$(run_mpc status "%elapsed%" 2>/dev/null)
        
        if [ -n "$CURRENT_STATUS" ] && [ "$CURRENT_STATUS" != "0" ]; then
            local state_file=$(get_state_file)
            echo "$CURRENT_STATUS $ELAPSED" > "$state_file"
        fi
        
        run_mpc stop >/dev/null 2>&1 || true
        run_mpc clear >/dev/null 2>&1 || true
}
