#!/bin/bash

# Глобальные настройки путей
MOUNT_POINT="/mnt/music"
TARGET_USER=$(id -nu 1000 2>/dev/null || echo "mabel")
USER_HOME=$(getent passwd "$TARGET_USER" | cut -d: -f6)
MPD_CONFIG_DIR="$USER_HOME/.config/mpd"

run_mpc() {
    sudo -u "$TARGET_USER" MPD_HOST=127.0.0.1 MPD_PORT=6600 /usr/bin/mpc "$@"
}

restart_user_mpd() {
    echo "Перезапуск пользовательского MPD..."
    sudo -u "$TARGET_USER" DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/1000/bus systemctl --user restart mpd.service
    sleep 0.8
}

get_uuid () {
    local device=$(mount | grep "/mnt/music" | egrep -o "^\/dev\/[a-z0-9]+")
    /sbin/blkid -o value -s UUID "$device" 2>/dev/null
}

get_state_file () {
    local uuid=$(get_uuid)
    echo "$MPD_CONFIG_DIR/$uuid/state"
}

# Функция для динамического перестроения mpd.conf под конкретную флешку
update_mpd_config() {
    local uuid=$(get_uuid)
    local db_file_path="$MPD_CONFIG_DIR/tag_cache" # дефолт

    # Если UUID передан, используем выделенную базу данных
    if [ -n "$uuid" ]; then
        db_file_path="$MPD_CONFIG_DIR/$uuid/tag_cache"
        # Создаем пустой файл базы, если флешка новая, чтобы у MPD были права
        touch "$db_file_path"
        chown "$TARGET_USER:$TARGET_USER" "$db_file_path"
    fi

    cat << EOF > "$mpd_config_dir/mpd.conf"
music_directory         "$MOUNT_POINT"
playlist_directory      "$MOUNT_POINT"
db_file                 "$db_file_path"
log_file                "$mpd_config_dir/mpd.log"
pid_file                "$mpd_config_dir/pid"
state_file              "$mpd_config_dir/state"
sticker_file            "$mpd_config_dir/sticker.sql"

audio_output {
        type            "pipewire"
        name            "PipeWire Bluetooth Output"
        mixer_type      "software"
}
EOF
    chown "$TARGET_USER:$TARGET_USER" "$mpd_config_dir/mpd.conf"
    restart_user_mpd
    run_mpc update
}

is_bluetooth_ready() {
    local connected_audio_found=0
    while read -r mac _; do
        if [ -n "$mac" ]; then
            if bluetoothctl info "$mac" | grep -q "Connected: yes"; then
                connected_audio_found=1
                break
            fi
        fi
    done < <(bluetoothctl devices | grep -E "JBL|audio-headset|headphone" | awk '{print $2}')

    if [ "$connected_audio_found" -eq 0 ] && bluetoothctl info | grep -q "Connected: yes"; then
        connected_audio_found=1
    fi
    [ "$connected_audio_found" -eq 1 ] && return 0 || return 1
}

start_playback() {
    local state_file=$(get_state_file)

    if [ -f "$state_file" ]; then
        read -r TRACK TIME < "$state_file"
        if [[ "$TRACK" =~ ^[0-9]+$ ]] && [[ "$TIME" =~ ^[0-9]+$ ]]; then
            echo "Восстановление позиции: Трек $TRACK, Время $TIME"
            run_mpc play "$TRACK"
            run_mpc seek "$TIME"
        else
            run_mpc play 1
        fi
    else
        if [ -f "$MOUNT_POINT/autoplay.m3u" ]; then
            run_mpc load autoplay
        else 
            run_mpc listall | run_mpc add
            run_mpc shuffle
        fi
    fi
    run_mpc repeat on
    run_mpc play
}
