#!/bin/bash

# Глобальные настройки путей
MOUNT_POINT="/mnt/music"
TARGET_USER=$(id -nu 1000 2>/dev/null || echo "mabel")
USER_HOME=$(getent passwd "$TARGET_USER" | cut -d: -f6)
MPD_CONFIG_DIR="$USER_HOME/.config/mpd"
MPD_CONFIG_FILE="$MPD_CONFIG_DIR/mpd.conf"
BT_MAC_FILE="$MPD_CONFIG_DIR/bt_mac"
CHIP="gpiochip1"
LINE=3

run_mpc() {
    sudo -u "$TARGET_USER" MPD_HOST=127.0.0.1 MPD_PORT=6600 /usr/bin/mpc "$@"
}

restart_user_mpd() {
    echo "Перезапуск пользовательского MPD..." | logger -t player-functions
    sudo -u "$TARGET_USER" DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/1000/bus systemctl --user restart mpd.service
    sleep 0.8
}

get_uuid () {
    # Надежный сбор устройства через mount
    local device=$(mount | grep "$MOUNT_POINT" | egrep -o "^\/dev\/[a-z0-9]+")
    /sbin/blkid -o value -s UUID "$device" 2>/dev/null
}

get_state_file () {
    local uuid=$(get_uuid)
    echo "$MPD_CONFIG_DIR/$uuid/state"
}

get_gravity_state () {
    gpioget -c "$CHIP" "$LINE" | cut -d'=' -f2 | tr -d '"'
}

update_mpd_config() {
    local uuid=$(get_uuid)
    local db_file_path="$MPD_CONFIG_DIR/tag_cache" 

    if [ -n "$uuid" ]; then
        db_dir="$MPD_CONFIG_DIR/$uuid"
        db_file_path="$db_dir/tag_cache"
        mkdir -p "$db_dir"
        touch "$db_file_path"
        chown "$TARGET_USER:$TARGET_USER" "$db_dir" -R
    fi

    cat << EOF > "$MPD_CONFIG_FILE"
music_directory         "$MOUNT_POINT"
playlist_directory      "$MOUNT_POINT"
db_file                 "$db_file_path"
log_file                "$MPD_CONFIG_DIR/mpd.log"
pid_file                "$MPD_CONFIG_DIR/pid"
state_file              "$MPD_CONFIG_DIR/state"
sticker_file            "$MPD_CONFIG_DIR/sticker.sql"

audio_output {
        type            "pipewire"
        name            "PipeWire Bluetooth Output"
        mixer_type      "software"
}
EOF
    chown "$TARGET_USER:$TARGET_USER" "$MPD_CONFIG_FILE"
}

find_connected_audio () {
    rm -f "$BT_MAC_FILE"
    # Ищем подключенные аудио-устройства среди всех известных девайсов
    bluetoothctl devices | egrep -o '([0-9A-Fa-f]{2}:){5}[0-9A-Fa-f]{2}' | while read mac; do
        if bluetoothctl info "$mac" | grep -q "Connected: yes"; then
            echo "$mac" > "$BT_MAC_FILE"
            break
        fi
    done
}

is_bluetooth_ready() {
    find_connected_audio
    [ -f "$BT_MAC_FILE" ] && return 0 || return 1
}

check_and_play () {
    local track="$1"
    local seek_time="$2"

    if [ -z "$(ls -A $MOUNT_POINT 2>/dev/null)" ]; then
        echo "Ошибка: Флешка не примонтирована или пуста." | logger -t player-functions
        return 0
    fi

    if [ "$(get_gravity_state)" = "active" ]; then
        echo "Проигрыватель перевёрнут, отмена старта." | logger -t player-functions
        return 0
    fi

    if ! is_bluetooth_ready; then
        echo "Ошибка: Нет подключенных аудиоустройств." | logger -t player-functions
        return 0
    else
        # Восстанавливаем коннект
        /usr/bin/bluetoothctl connect "$(cat $BT_MAC_FILE)" >/dev/null 2>&1
    fi

    run_mpc repeat on

    # Если переданы конкретные координаты трека (первый запуск флешки)
    if [ -n "$track" ] && [ -n "$seek_time" ]; then
        run_mpc play "$track"
        run_mpc seek "$seek_time"
    else
        # Во всех остальных случаях (снятие с паузы по датчику или D-Bus) — просто играем
        run_mpc play
    fi
}

start_playback() {
    echo "Инициализация новой флешки..." | logger -t player-functions
    update_mpd_config
    restart_user_mpd
    
    # Асинхронное фоновое обновление без блокирующего --wait
    run_mpc update >/dev/null 2>&1 || true

    local state_file=$(get_state_file)

    if [ -f "$state_file" ]; then
        read -r TRACK TIME < "$state_file"
        if [[ "$TRACK" =~ ^[0-9]+$ ]] && [[ "$TIME" =~ ^[0-9]+$ ]]; then
            echo "Найден файл состояния флешки. Восстановление позиции..." | logger -t player-functions
            check_and_play "$TRACK" "$TIME"
        else
            check_and_play
        fi
    else
        echo "Новая флешка без истории воспроизведения. Заполнение очереди..." | logger -t player-functions
        run_mpc clear
        if [ -f "$MOUNT_POINT/autoplay.m3u" ]; then
            run_mpc random off
            while read -r line || [ -n "$line" ]; do
                [[ "$line" =~ ^# ]] && continue
                [[ -z "$line" ]] && continue
                run_mpc add "$line"
            done < "$MOUNT_POINT/autoplay.m3u"
        else 
            run_mpc listall | run_mpc add
            run_mpc shuffle
        fi
        check_and_play
    fi
}

stop_playback () {
    echo "Остановка воспроизведения и сохранение состояния..." | logger -t player-functions
    CURRENT_STATUS=$(run_mpc status "%queuepos%" 2>/dev/null)
    ELAPSED=$(run_mpc status "%elapsed%" 2>/dev/null)
    
    if [ -n "$CURRENT_STATUS" ] && [ "$CURRENT_STATUS" != "0" ]; then
        local state_file=$(get_state_file)
        echo "$CURRENT_STATUS $ELAPSED" > "$state_file"
    fi
    
    run_mpc stop >/dev/null 2>&1 || true
    run_mpc clear >/dev/null 2>&1 || true
}
